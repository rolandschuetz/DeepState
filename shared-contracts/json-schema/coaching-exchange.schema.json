{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "oneOf": [
    {
      "type": "object",
      "properties": {
        "schema_version": {
          "type": "string",
          "const": "1.0.0"
        },
        "exchange_type": {
          "type": "string",
          "const": "morning_plan"
        },
        "local_date": {
          "type": "string",
          "format": "date",
          "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))$"
        },
        "total_intended_work_seconds": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "notes_for_tracker": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        },
        "tasks": {
          "minItems": 1,
          "maxItems": 3,
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "title": {
                "type": "string",
                "minLength": 1
              },
              "success_definition": {
                "type": "string",
                "minLength": 1
              },
              "total_remaining_effort_seconds": {
                "anyOf": [
                  {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 9007199254740991
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "intended_work_seconds_today": {
                "type": "integer",
                "minimum": 0,
                "maximum": 9007199254740991
              },
              "progress_kind": {
                "type": "string",
                "enum": [
                  "time_based",
                  "milestone_based",
                  "artifact_based",
                  "hybrid"
                ]
              },
              "allowed_support_work": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "likely_detours_that_still_count": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "required": [
              "title",
              "success_definition",
              "total_remaining_effort_seconds",
              "intended_work_seconds_today",
              "progress_kind",
              "allowed_support_work",
              "likely_detours_that_still_count"
            ],
            "additionalProperties": false
          }
        }
      },
      "required": [
        "schema_version",
        "exchange_type",
        "local_date",
        "total_intended_work_seconds",
        "notes_for_tracker",
        "tasks"
      ],
      "additionalProperties": false
    },
    {
      "type": "object",
      "properties": {
        "schema_version": {
          "type": "string",
          "const": "1.0.0"
        },
        "exchange_type": {
          "type": "string",
          "const": "evening_debrief"
        },
        "local_date": {
          "type": "string",
          "format": "date",
          "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))$"
        },
        "overall_day_summary": {
          "type": "string",
          "minLength": 1
        },
        "task_outcomes": {
          "minItems": 1,
          "maxItems": 3,
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "task_title": {
                "type": "string",
                "minLength": 1
              },
              "did_progress_occur": {
                "type": "string",
                "enum": [
                  "yes",
                  "no",
                  "partial"
                ]
              },
              "what_counted_as_real_progress": {
                "anyOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "what_was_support_work": {
                "anyOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "what_was_misclassified_or_ambiguous": {
                "anyOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "null"
                  }
                ]
              }
            },
            "required": [
              "task_title",
              "did_progress_occur",
              "what_counted_as_real_progress",
              "what_was_support_work",
              "what_was_misclassified_or_ambiguous"
            ],
            "additionalProperties": false
          }
        },
        "new_support_patterns_to_remember": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "patterns_to_not_remember": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "corrections_for_task_boundaries": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        },
        "carry_forward_to_tomorrow": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        },
        "coaching_note_for_tomorrow": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "schema_version",
        "exchange_type",
        "local_date",
        "overall_day_summary",
        "task_outcomes",
        "new_support_patterns_to_remember",
        "patterns_to_not_remember",
        "corrections_for_task_boundaries",
        "carry_forward_to_tomorrow",
        "coaching_note_for_tomorrow"
      ],
      "additionalProperties": false
    }
  ]
}
