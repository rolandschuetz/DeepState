{
  "name": "@ineedabossagent/logic",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "start": "tsx src/cli/run-logic-runtime.ts",
    "build": "tsc --noEmit",
    "build:sea": "node scripts/build-sea-binary.mjs",
    "generate:migration-fixture": "tsx scripts/generate-migration-smoke-test-fixture.ts",
    "lint": "eslint scripts src tests vitest.config.ts --max-warnings=0",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ineedabossagent/shared-contracts": "file:../shared-contracts",
    "better-sqlite3": "^12.4.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.8.1",
    "esbuild": "^0.25.11",
    "eslint": "^9.39.1",
    "globals": "^16.5.0",
    "postject": "^1.0.0-alpha.6",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.2",
    "vitest": "^3.2.4"
  }
}
